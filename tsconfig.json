{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "paths": {
      "~/*": [
        ".vitepress/*"
      ]
    }
  },
  "include": [
    ".vitepress/**/*.mts",
    ".vitepress/**/*.ts",
    ".vitepress/**/*.vue",
    "src/**/*.md"
  ]
}
